NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LANGUAGE=en

# Database
DATABASE_URL=postgresql://asoode:asoode@localhost:5432/asoode?schema=public

# JWT
JWT_SECRET=asoode-jwt-secret-change-in-production
JWT_EXPIRES_IN=30d

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
QUEUE_PREFIX=asoode

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET=asoode
