{
  "name": "@asoode/backend",
  "private": true,
  "version": "1.0.0",
  "description": "Asoode REST API backend",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "start:debug": "nest start --debug --watch",
    "lint": "tsc --noEmit",
